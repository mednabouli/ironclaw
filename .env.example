# ─────────────────────────────────────────────────────────────────────────
#  IronClaw — Environment Variables
#  Copy this file to .env and fill in your values.
#  .env is git-ignored. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────

# ── Logging ──────────────────────────────────────────────────────────────
# Controls tracing output. Format: <level> or <crate>=<level>
# Levels: error | warn | info | debug | trace
RUST_LOG=ironclaw=info

# ── Ollama (default provider — no API key needed) ────────────────────────
# Base URL of your Ollama instance. Default: http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434

# Default model for Ollama completions
# OLLAMA_MODEL=llama3.2

# ── Anthropic Claude ─────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
# Starts with sk-ant-
ANTHROPIC_API_KEY=

# ── OpenAI ───────────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
# Starts with sk-
OPENAI_API_KEY=

# ── Groq ─────────────────────────────────────────────────────────────────
# Get your key at: https://console.groq.com
# Starts with gsk_
GROQ_API_KEY=

# ── OpenRouter (v0.6.0+) ─────────────────────────────────────────────────
# Access 100+ models via one key: https://openrouter.ai/keys
# Starts with sk-or-
OPENROUTER_API_KEY=

# ── Mistral AI (v0.6.0+) ─────────────────────────────────────────────────
# Get your key at: https://console.mistral.ai
MISTRAL_API_KEY=

# ── Together AI (v0.6.0+) ────────────────────────────────────────────────
# Get your key at: https://api.together.xyz
TOGETHER_API_KEY=

# ── Cohere (v0.6.0+) ─────────────────────────────────────────────────────
# Get your key at: https://dashboard.cohere.com
COHERE_API_KEY=

# ── Google Gemini (v0.6.0+) ──────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── REST Channel ─────────────────────────────────────────────────────────
# Bearer token for REST API auth. Set a long random string.
# Generate one: openssl rand -hex 32
REST_AUTH_TOKEN=

# ── Telegram Channel (v0.5.0+) ───────────────────────────────────────────
# Create a bot via @BotFather and paste the token here.
# Format: 123456789:ABCDefGhiJklMnopQrsTUVwxYZ
TELEGRAM_TOKEN=

# ── Discord Channel (v0.5.0+) ────────────────────────────────────────────
# Create an application at: https://discord.com/developers/applications
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# ── Telegram (ntfy.sh) (v0.5.0+) ─────────────────────────────────────────
# Topic name on ntfy.sh for push notifications
# NTFY_TOPIC=ironclaw-alerts

# ── Observability (v0.9.0+) ──────────────────────────────────────────────
# OTLP endpoint for OpenTelemetry traces (Jaeger, Grafana Tempo, etc.)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=ironclaw

# ── Secrets Vault (v0.9.0+) ──────────────────────────────────────────────
# HashiCorp Vault address (leave blank to use env vars directly)
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=

# ── AWS (Bedrock / Secrets Manager) ──────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── Fine-tuning / Eval (v0.10.0+) ────────────────────────────────────────
# HUGGINGFACE_TOKEN=hf_...

# ─────────────────────────────────────────────────────────────────────────
# NOTES:
# - All values here can also be set in ironclaw.toml using ${VAR_NAME}
# - ironclaw.toml takes precedence over .env for non-secret config
# - Run `ironclaw doctor` to verify your environment is configured correctly
# - Run `ironclaw health` to check which providers are reachable
# ─────────────────────────────────────────────────────────────────────────
